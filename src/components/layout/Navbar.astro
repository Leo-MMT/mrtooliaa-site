---
/**
 * Navbar — Adaptive navigation bar.
 * - home: transparent bg with animated SVG logo, scrolls to nav-scrolled
 * - mediturno: white bg with blue accents
 * - ferretquote: dark bg with orange accents
 */
import { waLink } from '@data/site';

interface Props {
  variant?: 'home' | 'mediturno' | 'ferretquote';
}

const { variant = 'home' } = Astro.props;

const navLinks: Record<string, { label: string; href: string }[]> = {
  home: [
    { label: 'Soluciones', href: '#solution' },
    { label: 'Productos', href: '#products' },
    { label: 'Cómo funciona', href: '#how' },
    { label: 'Precios', href: '#pricing' },
  ],
  mediturno: [
    { label: '← MR ToolIAA', href: '/' },
    { label: 'Cómo funciona', href: '#como-funciona' },
    { label: 'Beneficios', href: '#beneficios' },
    { label: 'Precios', href: '#precios' },
  ],
  ferretquote: [
    { label: '← MR ToolIAA', href: '/' },
    { label: 'El Problema', href: '#problema' },
    { label: 'La Solución', href: '#solucion' },
    { label: 'Precios', href: '#precios' },
    { label: 'FAQ', href: '#faq' },
  ],
};

const links = navLinks[variant] ?? navLinks.home;

const waMessages: Record<string, string> = {
  home: 'Hola, me interesa saber más sobre los agentes IA de MR ToolIAA',
  mediturno: 'Hola, me interesa una demo de MediTurno IA',
  ferretquote: 'Hola, me interesa Ferret-Quote Bot para mi ferretería',
};

const ctaLabels: Record<string, { desktop: string; mobile: string }> = {
  home: { desktop: 'Hablar con un experto', mobile: 'Contactar' },
  mediturno: { desktop: 'Prueba gratis', mobile: 'Prueba gratis' },
  ferretquote: { desktop: 'Empezar gratis', mobile: 'Empezar' },
};

const bgStyles: Record<string, string> = {
  home: 'background: transparent;',
  mediturno: 'background: rgba(255,255,255,0.97); box-shadow: 0 2px 20px rgba(0,0,0,0.08);',
  ferretquote: 'background: rgba(31,41,55,0.97); box-shadow: 0 2px 20px rgba(0,0,0,0.3);',
};

const linkColor = variant === 'mediturno' ? 'text-gray-600 hover:text-medical-500' : 'text-white/80 hover:text-white';
const ctaColor = variant === 'mediturno'
  ? 'bg-medical-500 hover:bg-medical-600 text-white'
  : variant === 'ferretquote'
    ? 'bg-brand-500 hover:bg-brand-600 text-white'
    : 'bg-brand-500 hover:bg-brand-600 text-white';

const isHome = variant === 'home';
---
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style={bgStyles[variant]}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    {isHome ? (
      <a id="navLogoLink" href="#" class="flex items-center gap-3" aria-label="MR ToolIAA — inicio">
        <span id="navLogo" class="logo-nav inline-flex" style="will-change: transform;">
          <img src="/assets/logo.webp" alt="MR ToolIAA" width="100" height="100" class="h-24 w-auto" loading="eager" decoding="async" />
        </span>
        <span class="hidden sm:inline-flex flex-col leading-none">
          <span class="text-white font-black text-2xl tracking-tight">MR Tool<span class="text-cyan-400">IAA</span></span>
          <span class="text-white/50 text-[11px] font-semibold uppercase tracking-[0.18em] mt-1">Agentes IA · RD</span>
        </span>
      </a>
    ) : variant === 'mediturno' ? (
      <a href="/mediturno/" class="flex items-center gap-3" aria-label="MediTurno IA">
        <img src="/assets/logo-mediturno-icon.png" alt="" width="48" height="48" class="h-12 w-auto" />
        <span class="font-black text-xl text-gray-800">Medi<span class="text-medical-500">Turno</span> <span class="text-gray-400 text-sm">IA</span></span>
      </a>
    ) : (
      <a href="/ferretquote/" class="flex items-center gap-3" aria-label="Ferret-Quote Bot">
        <img src="/assets/logo-ferretquote-icon.png" alt="" width="48" height="48" class="h-12 w-auto" />
        <span class="font-black text-xl text-white">Ferret-Quote <span class="text-brand-500">Bot</span></span>
      </a>
    )}

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(l => (
        <a href={l.href} class:list={[linkColor, 'text-base font-semibold transition-colors']}>{l.label}</a>
      ))}
      <a href={waLink(waMessages[variant])} target="_blank" rel="noopener noreferrer"
         class:list={[ctaColor, 'text-base font-bold px-6 py-3 rounded-full transition-colors shadow-lg']}>
        {ctaLabels[variant].desktop}
      </a>
    </div>

    <!-- Mobile CTA -->
    <a href={waLink(waMessages[variant])} target="_blank" rel="noopener noreferrer"
       class:list={['md:hidden', ctaColor, 'text-sm font-bold px-4 py-2 rounded-full']}>
      {ctaLabels[variant].mobile}
    </a>
  </div>
</nav>
{isHome && <script src="/assets/js/main.js" defer />}
