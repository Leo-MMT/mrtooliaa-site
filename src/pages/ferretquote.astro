---
import BaseLayout from '@layouts/BaseLayout.astro';
import { waLink } from '@data/site';
import { ferretquote } from '@data/ferretquote';
---
<BaseLayout
  seo={{ ...ferretquote.seo, jsonLd: ferretquote.jsonLd, favicon: ferretquote.logos.icon }}
  navVariant="ferretquote"
  footerVariant="ferretquote"
  waMessage={ferretquote.wa.interest}
>

  <!-- HERO -->
  <section class="hero-bg min-h-screen flex items-center pt-20 pb-16 relative overflow-hidden">
    <div class="stripe-accent h-2 absolute top-0 left-0 right-0"></div>
    <div class="absolute inset-0 overflow-hidden pointer-events-none select-none" aria-hidden="true">
      <span class="absolute text-[200px] opacity-5 -bottom-10 right-[-30px] rotate-6">🔧</span>
      <span class="absolute text-[100px] opacity-5 top-40 left-[-20px] -rotate-12">🔩</span>
    </div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-brand-500/20 text-brand-400 text-sm font-bold px-4 py-2 rounded-full mb-6">
            <span>🔩</span> Bot para ferreterías
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            Tu ferretería<br/><span class="text-brand-500">cotiza en segundos</span><br/>por WhatsApp
          </h1>
          <p class="text-gray-300 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl">{ferretquote.tagline} El bot responde precios al instante y genera cotizaciones PDF profesionales — sin que tú muevas un dedo.</p>
          <div class="flex flex-wrap gap-4 mb-6">
            <a href={waLink(ferretquote.wa.activate)} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-black px-8 py-4 rounded-full text-lg shadow-xl shadow-orange-500/30 transition-colors cta-pulse">
              <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                <path d="M23.5 8.5A10.45 10.45 0 0 0 16 5.5C10.2 5.5 5.5 10.2 5.5 16c0 1.85.49 3.66 1.41 5.25L5.5 26.5l5.38-1.41A10.46 10.46 0 0 0 16 26.5c5.8 0 10.5-4.7 10.5-10.5 0-2.8-1.09-5.43-3-7.5Z" fill="white"/>
              </svg>
              Empezar gratis — primera semana
            </a>
          </div>
          <p class="text-gray-500 text-sm">Sin contrato · Sin tarjeta · Activación en 48h</p>
        </div>
        <div class="hidden lg:block relative">
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 p-6 shadow-2xl">
            <div class="flex items-center gap-3 mb-4 pb-4 border-b border-white/10">
              <img src={ferretquote.logos.icon} alt="" width="40" height="40" class="h-10 w-auto" />
              <div><div class="text-white font-bold text-sm">Ferret-Quote Bot</div><div class="text-green-400 text-xs">● En línea 24/7</div></div>
            </div>
            <div class="space-y-3">
              <div class="flex justify-end"><div class="bg-brand-500/20 text-white text-sm px-4 py-3 rounded-2xl rounded-br-md max-w-xs">¿Cuánto está el cemento gris?</div></div>
              <div class="flex"><div class="bg-white/10 text-white text-sm px-4 py-3 rounded-2xl rounded-bl-md max-w-sm">Cemento Gris Portland 42.5kg — <strong>RD$465</strong><br/>¿Quieres una cotización PDF?</div></div>
              <div class="flex justify-end"><div class="bg-brand-500/20 text-white text-sm px-4 py-3 rounded-2xl rounded-br-md">Sí, agrega 10 bloques de 6"</div></div>
              <div class="flex"><div class="bg-white/10 text-white/80 text-sm px-4 py-3 rounded-2xl rounded-bl-md animate-pulse">📄 Generando cotización PDF...</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-4 bg-brand-500 text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      {ferretquote.stats.map(s => (
        <div class="py-3">
          <div class="text-2xl font-black">{s.value}</div>
          <div class="text-white/80 text-sm">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROBLEM -->
  <section id="problema" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <div class="bolt-divider justify-center">
          <span class="text-brand-500 text-sm font-bold uppercase tracking-widest px-4">El problema</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-gray-800">
          Cada minuto que tardas en cotizar,<br/><span class="text-brand-500">pierdes una venta</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {ferretquote.problems.map(p => (
          <div class="pain-card bg-gray-50 rounded-2xl p-7 border-2 border-gray-200 hover:border-brand-500">
            <div class="text-4xl mb-4">{p.icon}</div>
            <h3 class="text-lg font-black text-gray-800 mb-2">{p.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">{p.description}</p>
            <span class:list={['text-xs font-bold px-3 py-1 rounded-full',
              p.badgeColor === 'red' ? 'bg-red-50 text-red-500' :
              p.badgeColor === 'orange' ? 'bg-orange-50 text-orange-500' : 'bg-yellow-50 text-yellow-600'
            ]}>{p.badge}</span>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center bg-gray-900 text-white rounded-2xl p-6">
        <p class="text-lg">{ferretquote.bridgeCallout.text} <strong class="text-brand-500 text-2xl font-black">{ferretquote.bridgeCallout.accent}</strong> {ferretquote.bridgeCallout.suffix}</p>
      </div>
    </div>
  </section>

  <!-- SOLUTION / FEATURES -->
  <section id="solucion" class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <div class="bolt-divider justify-center">
          <span class="text-brand-500 text-sm font-bold uppercase tracking-widest px-4">La solución</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-gray-800">
          Ferret-Quote Bot cotiza<br/><span class="text-brand-500">en menos de 5 segundos</span>
        </h2>
      </div>
      <div class="space-y-4">
        {ferretquote.features.map(f => (
          <div class="feature-row bg-white rounded-2xl p-6 border border-gray-100 flex items-start gap-5">
            <div class="text-3xl flex-shrink-0">{f.icon}</div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1">
                <h3 class="font-black text-lg text-gray-800">{f.title}</h3>
                <span class:list={['text-xs font-bold px-2 py-0.5 rounded-full',
                  f.badgeColor === 'green' ? 'bg-green-50 text-green-600' :
                  f.badgeColor === 'blue' ? 'bg-blue-50 text-blue-600' :
                  f.badgeColor === 'purple' ? 'bg-purple-50 text-purple-600' :
                  f.badgeColor === 'orange' ? 'bg-orange-50 text-orange-600' : 'bg-gray-100 text-gray-600'
                ]}>{f.badge}</span>
              </div>
              <p class="text-gray-500 text-sm">{f.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <div class="bolt-divider justify-center">
          <span class="text-brand-500 text-sm font-bold uppercase tracking-widest px-4">Cómo funciona</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-gray-800">
          Del mensaje del cliente<br/><span class="text-brand-500">al PDF en segundos</span>
        </h2>
      </div>
      <div class="space-y-8 max-w-2xl mx-auto">
        {ferretquote.process.map(step => (
          <div class="flex items-start gap-6">
            <div class="step-num">{step.step}</div>
            <div>
              <h3 class="font-black text-lg text-gray-800 mb-1">{step.title}</h3>
              <p class="text-gray-500 text-sm">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="precios" class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <div class="bolt-divider justify-center">
          <span class="text-brand-500 text-sm font-bold uppercase tracking-widest px-4">Planes y precios</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-gray-800">
          Inversión que se paga sola<br/><span class="text-brand-500">desde la primera semana</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6 items-start">
        <!-- Setup -->
        <div class="bg-white rounded-2xl p-7 border-2 border-gray-200 shadow-sm">
          <div class="text-3xl mb-4" aria-hidden="true">🔧</div>
          <h3 class="text-xl font-black text-gray-800">Setup Inicial</h3>
          <p class="text-gray-500 text-sm mt-1 mb-5">Pago único al contratar</p>
          <div class="mb-5">
            <span class="text-4xl font-black text-gray-800">RD${ferretquote.pricing.setup.price.toLocaleString()}</span>
            <span class="text-gray-400 text-sm ml-1">único</span>
          </div>
          <ul class="space-y-2.5 mb-7">
            {ferretquote.pricing.setup.features.map(f => (
              <li class="flex items-start gap-2.5 text-sm text-gray-600">
                <span class="text-green-500 font-bold mt-0.5">✓</span> {f}
              </li>
            ))}
          </ul>
          <a href={waLink(ferretquote.wa.interest)} target="_blank" rel="noopener noreferrer"
             class="block text-center border-2 border-gray-300 hover:border-brand-500 text-gray-800 hover:text-brand-500 font-bold py-3 rounded-xl text-sm transition-colors">
            Preguntar por setup
          </a>
        </div>

        {ferretquote.pricing.plans.map(plan => (
          <div class:list={['rounded-2xl p-7 relative',
            plan.variant === 'popular' ? 'pricing-popular bg-gray-800 shadow-xl' : 'bg-white border-2 border-gray-200 shadow-sm'
          ]}>
            {plan.popular && <div class="ribbon">MÁS POPULAR</div>}
            <div class="text-3xl mb-4" aria-hidden="true">{plan.popular ? '🏆' : '⚡'}</div>
            <h3 class:list={['text-xl font-black', plan.variant === 'popular' ? 'text-white' : 'text-gray-800']}>{plan.name}</h3>
            <p class:list={['text-sm mt-1 mb-5', plan.variant === 'popular' ? 'text-gray-400' : 'text-gray-500']}>{plan.description}</p>
            <div class="mb-5">
              <span class:list={['text-4xl font-black', plan.variant === 'popular' ? 'text-white' : 'text-gray-800']}>RD${plan.price.toLocaleString()}</span>
              <span class:list={['text-sm ml-1', plan.variant === 'popular' ? 'text-gray-400' : 'text-gray-400']}>{plan.period}</span>
            </div>
            <ul class="space-y-2.5 mb-7">
              {plan.features.map(f => (
                <li class:list={['flex items-start gap-2.5 text-sm', plan.variant === 'popular' ? 'text-gray-300' : 'text-gray-600']}>
                  <span class:list={['font-bold mt-0.5', plan.variant === 'popular' ? 'text-brand-500' : 'text-green-500']}>✓</span> {f}
                </li>
              ))}
              {plan.excluded?.map(f => (
                <li class="flex items-start gap-2.5 text-sm text-gray-400">
                  <span class="text-gray-300 font-bold mt-0.5">✗</span> <span class="text-gray-400">{f}</span>
                </li>
              ))}
            </ul>
            <a href={waLink(ferretquote.wa.interest)} target="_blank" rel="noopener noreferrer"
               class:list={['block text-center font-bold py-3 rounded-xl text-sm transition-all',
                plan.variant === 'popular' ? 'bg-brand-500 hover:bg-brand-600 text-white shadow-md cta-pulse' :
                'border-2 border-brand-500 text-brand-500 hover:bg-brand-500 hover:text-white'
              ]}>Empezar con {plan.name.replace('Plan ', '')}</a>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <div class="inline-flex flex-col sm:flex-row items-center gap-5 bg-white border-2 border-brand-500 rounded-2xl px-8 py-6 shadow-sm">
          <div class="text-5xl" aria-hidden="true">🎁</div>
          <div class="text-center sm:text-left">
            <div class="text-xl font-black text-gray-800">{ferretquote.pricing.freeWeek}</div>
            <div class="text-gray-500 text-sm mt-1">Sin tarjeta de crédito. Sin compromiso. Cancela cuando quieras.</div>
          </div>
          <a href={waLink(ferretquote.wa.activate)} target="_blank" rel="noopener noreferrer"
             class="flex-shrink-0 flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-black px-7 py-3 rounded-xl text-sm transition-colors">
            Quiero mi semana gratis
          </a>
        </div>
      </div>
      <p class="text-center text-gray-400 text-xs mt-6">{ferretquote.pricing.note}</p>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <div class="bolt-divider justify-center">
          <span class="text-brand-500 text-sm font-bold uppercase tracking-widest px-4">Preguntas frecuentes</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-gray-800">
          Lo que los dueños de ferretería<br/><span class="text-brand-500">siempre preguntan</span>
        </h2>
      </div>
      <div class="space-y-3">
        {ferretquote.faq.map(item => (
          <details class="group bg-gray-50 border-2 border-gray-200 rounded-2xl overflow-hidden hover:border-brand-500 transition-colors">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 font-bold text-gray-800 text-base cursor-pointer select-none">
              <span>{item.q}</span>
            </summary>
            <div class="faq-body px-6 pb-5">
              <p class="text-gray-600 text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
      <div class="text-center mt-10">
        <p class="text-gray-500 text-sm mb-4">¿Tienes otra pregunta que no está aquí?</p>
        <a href={waLink(ferretquote.wa.question)} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 text-brand-500 font-bold border-2 border-brand-500 hover:bg-brand-500 hover:text-white px-6 py-3 rounded-xl text-sm transition-all">
          Preguntar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-20 hero-bg text-white overflow-hidden relative">
    <div class="stripe-accent h-2 absolute top-0 left-0 right-0"></div>
    <div class="absolute inset-0 overflow-hidden pointer-events-none select-none" aria-hidden="true">
      <span class="absolute text-[200px] opacity-5 -bottom-10 right-[-30px] rotate-6">🔧</span>
      <span class="absolute text-[100px] opacity-5 top-10 left-[-20px] -rotate-12">🔩</span>
    </div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 relative text-center">
      <div class="text-7xl mb-6" aria-hidden="true">🔩</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6">
        ¿Listo para que tu ferretería<br/><span class="text-brand-500">cotice sola?</span>
      </h2>
      <p class="text-gray-300 text-xl md:text-2xl leading-relaxed mb-4 max-w-2xl mx-auto">
        Deja de perder ventas por tardanza. Empieza hoy con <strong class="text-white">una semana completamente gratis</strong> — sin tarjeta, sin compromiso.
      </p>
      <p class="text-gray-400 text-base mb-10 max-w-xl mx-auto">
        En menos de 48 horas tu ferretería estará cotizando automáticamente por WhatsApp.
      </p>
      <a href={waLink(ferretquote.wa.activate)} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-4 bg-[#25d366] hover:bg-[#1db856] text-white font-black px-10 py-5 rounded-2xl text-xl transition-all shadow-xl cta-pulse"
         style="box-shadow: 0 8px 32px rgba(37,211,102,0.45);">
        <svg class="w-8 h-8 flex-shrink-0" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <path d="M23.5 8.5A10.45 10.45 0 0 0 16 5.5C10.2 5.5 5.5 10.2 5.5 16c0 1.85.49 3.66 1.41 5.25L5.5 26.5l5.38-1.41A10.46 10.46 0 0 0 16 26.5c5.8 0 10.5-4.7 10.5-10.5 0-2.8-1.09-5.43-3-7.5Z" fill="white"/>
        </svg>
        Empezar ahora — primera semana gratis
      </a>
      <p class="text-gray-500 text-sm mt-3">O escríbenos con tus preguntas, sin presión.</p>
      <div class="flex flex-wrap justify-center gap-6 mt-12 pt-10 border-t border-gray-700">
        {ferretquote.trustBadges.map(b => (
          <div class="flex items-center gap-2 text-gray-400 text-sm">
            <span class="text-xl">{b.icon}</span>
            <span>{b.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
