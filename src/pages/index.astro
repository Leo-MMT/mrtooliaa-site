---
/**
 * MR ToolIAA — Corporate landing page
 * Renders the full home page from centralized data + shared components.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { site, waLink } from '@data/site';
import { mrtooliaa } from '@data/mrtooliaa';
import SectionHeader from '@components/shared/SectionHeader.astro';
---
<BaseLayout
  seo={{ ...mrtooliaa.seo, jsonLd: mrtooliaa.jsonLd }}
  navVariant="home"
  footerVariant="home"
>

  <!-- ======================================================
       HERO
  ======================================================= -->
  <section class="gradient-hero min-h-screen flex items-center pt-20 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 right-0 w-96 h-96 bg-brand-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/4 w-64 h-64 bg-white/3 rounded-full blur-2xl"></div>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            {mrtooliaa.hero.title.line1}<br/>
            <span class="text-brand-500">{mrtooliaa.hero.title.accent}</span><br/>
            {mrtooliaa.hero.title.line3}
          </h1>
          <p class="text-white/60 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl">
            {mrtooliaa.hero.subtitle}
          </p>
          <div class="flex flex-wrap gap-4 mb-10">
            <a href={mrtooliaa.hero.ctaPrimary.href}
               class="gradient-cta text-white font-bold px-8 py-4 rounded-full text-lg shadow-xl shadow-orange-500/30 hover:shadow-orange-500/50 transition-shadow">
              {mrtooliaa.hero.ctaPrimary.text}
            </a>
            <a href={mrtooliaa.hero.ctaSecondary.href} target="_blank" rel="noopener noreferrer"
               class="border border-white/30 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-colors">
              {mrtooliaa.hero.ctaSecondary.text}
            </a>
          </div>
          <div class="grid grid-cols-3 gap-6 border-t border-white/10 pt-8">
            {mrtooliaa.hero.stats.map(s => (
              <div>
                <div class:list={['text-3xl font-black', s.accent ? 'text-brand-500' : 'text-white']}>{s.value}</div>
                <div class="text-white/50 text-sm mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="hidden lg:block relative">
          <div class="relative bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 p-6 shadow-2xl">
            <div class="flex items-center gap-3 mb-6 pb-4 border-b border-white/10">
              <div class="w-10 h-10 bg-brand-500 rounded-full flex items-center justify-center text-white font-bold">IA</div>
              <div><div class="text-white font-bold text-sm">MR ToolIAA Agent</div><div class="text-green-400 text-xs">● En línea</div></div>
            </div>
            <div class="space-y-4">
              <div class="flex justify-end"><div class="bg-brand-500/20 text-white/90 text-sm px-4 py-3 rounded-2xl rounded-br-md max-w-xs">¿Cuánto cuesta el cemento gris?</div></div>
              <div class="flex"><div class="bg-white/10 text-white/90 text-sm px-4 py-3 rounded-2xl rounded-bl-md max-w-sm">Cemento gris Portland 42.5kg — <strong>RD$465</strong>. ¿Quieres que genere una cotización PDF con este y otros productos?</div></div>
              <div class="flex justify-end"><div class="bg-brand-500/20 text-white/90 text-sm px-4 py-3 rounded-2xl rounded-br-md max-w-xs">Sí, agrega 10 bloques de 6"</div></div>
              <div class="flex"><div class="bg-white/10 text-white/80 text-sm px-4 py-3 rounded-2xl rounded-bl-md animate-pulse">Generando cotización PDF...</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================
       PROBLEM / SOLUTION STRIP
  ======================================================= -->
  <section id="solution" class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="El problema" title="Tu equipo repite tareas." titleAccent="Nuestros agentes las eliminan." />
      <div class="grid md:grid-cols-3 gap-8">
        {mrtooliaa.problems.map(p => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 card-hover text-center">
            <div class="text-4xl mb-4">{p.icon === 'bot' ? '🤖' : p.icon === 'target' ? '🎯' : p.icon}</div>
            <h3 class="text-xl font-black text-navy-500 mb-3">{p.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{p.description}</p>
            <span class:list={['inline-block mt-4 px-3 py-1 text-xs font-bold rounded-full',
              p.variant === 'red' ? 'bg-red-50 text-red-500' :
              p.variant === 'green' ? 'bg-green-50 text-green-600' : 'bg-navy-50 text-navy-500'
            ]}>{p.badge}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================
       ROI CALLOUT
  ======================================================= -->
  <section class="py-4 bg-navy-500 text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-center gap-6 text-center sm:text-left">
      <div class="flex items-center gap-4">
        <span class="text-6xl font-black text-brand-500">{mrtooliaa.roiCallout.value}</span>
        <div><div class="text-2xl font-bold">{mrtooliaa.roiCallout.unit}</div><div class="text-white/60 text-sm">{mrtooliaa.roiCallout.description}</div></div>
      </div>
    </div>
  </section>

  <!-- ======================================================
       PRODUCTS
  ======================================================= -->
  <section id="products" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="Productos" title="Soluciones IA" titleAccent="listas para tu industria" description="Agentes especializados por sector — listos para implementar en días, no meses." />
      <div class="grid md:grid-cols-3 gap-8">
        {mrtooliaa.products.map(product => (
          <div class:list={['rounded-2xl p-8 card-hover border', product.variant === 'dark' ? 'bg-navy-500 text-white border-navy-500' : product.variant === 'active' ? 'bg-white shadow-lg product-card-active' : 'bg-white shadow-sm border-gray-100']}>
            {product.logo && <img src={product.logo} alt="" width="48" height="48" class="h-12 w-auto mb-4" loading="lazy" decoding="async" />}
            <span class:list={['text-xs font-bold uppercase tracking-wider', product.audienceColor === 'blue' ? 'text-medical-500' : product.audienceColor === 'orange' ? 'text-brand-500' : 'text-white/60']}>{product.audience}</span>
            <h3 class:list={['text-xl font-black mt-2 mb-3', product.variant === 'dark' ? 'text-white' : 'text-navy-500']}>{product.name}</h3>
            <p class:list={['text-sm leading-relaxed mb-4', product.variant === 'dark' ? 'text-white/60' : 'text-gray-500']}>{product.description}</p>
            <ul class:list={['space-y-2 mb-6 text-sm', product.variant === 'dark' ? 'text-white/70' : 'text-gray-600']}>
              {product.features.map(f => (
                <li class="flex items-center gap-2"><span class="text-brand-500 font-bold">✓</span> {f}</li>
              ))}
            </ul>
            <a href={product.cta.href} class:list={['block text-center font-bold py-3 rounded-xl text-sm transition-colors',
              product.variant === 'active' ? 'gradient-cta text-white shadow-lg hover:opacity-90' :
              product.variant === 'dark' ? 'bg-white/15 hover:bg-white/25 text-white border border-white/20' :
              'border-2 border-navy-500 text-navy-500 hover:bg-navy-500 hover:text-white'
            ]}>{product.cta.text}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================
       HOW IT WORKS
  ======================================================= -->
  <section id="how" class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="Proceso" title="Implementación en" titleAccent="7 días" description="De la primera llamada a agente IA en producción — sin complicaciones." />
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {mrtooliaa.process.map(step => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 card-hover text-center relative">
            <div class="text-4xl mb-4">{step.icon}</div>
            <div class="inline-flex items-center justify-center w-8 h-8 bg-brand-500 text-white text-sm font-black rounded-full mb-3">{step.step}</div>
            <h3 class="text-lg font-black text-navy-500 mb-2">{step.title}</h3>
            <p class="text-gray-500 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {mrtooliaa.timeline.map(t => (
          <div class:list={['text-center p-4 rounded-xl', t.accent ? 'bg-brand-500 text-white' : 'bg-white border border-gray-100']}>
            <div class:list={['text-sm font-bold', t.accent ? 'text-white/80' : 'text-brand-500']}>{t.day}</div>
            <div class:list={['font-black text-lg', t.accent ? '' : 'text-navy-500']}>{t.title}</div>
            <div class:list={['text-xs mt-1', t.accent ? 'text-white/70' : 'text-gray-400']}>{t.subtitle}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================
       WHY MR TOOLIAA
  ======================================================= -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="¿Por qué nosotros?" title="Lo que nos hace" titleAccent="diferentes" />
      <div class="grid md:grid-cols-3 gap-6">
        {mrtooliaa.differentiators.map(d => (
          <div class:list={['rounded-2xl p-6 card-hover', d.highlight ? 'bg-brand-500 text-white shadow-lg' : 'bg-gray-50 border border-gray-100']}>
            <div class="text-3xl mb-3">{d.icon}</div>
            <h3 class:list={['font-black text-lg mb-2', d.highlight ? '' : 'text-navy-500']}>{d.title}</h3>
            <p class:list={['text-sm leading-relaxed', d.highlight ? 'text-white/80' : 'text-gray-500']}>{d.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================
       TESTIMONIALS
  ======================================================= -->
  <section class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="Testimonios" title="Lo que dicen" titleAccent="nuestros clientes" />
      <div class="grid md:grid-cols-3 gap-8">
        {mrtooliaa.testimonials.map(t => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 testimonial-card">
            <p class="text-gray-600 text-sm leading-relaxed mb-6">{t.quote}</p>
            <div class="flex items-center gap-3">
              <div class:list={['w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm',
                t.color === 'brand' ? 'bg-brand-500' : t.color === 'green' ? 'bg-green-500' : 'bg-navy-500'
              ]}>{t.initials}</div>
              <div><div class="font-bold text-navy-500 text-sm">{t.name}</div><div class="text-gray-400 text-xs">{t.role}</div></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================
       PRICING
  ======================================================= -->
  <section id="pricing" class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="Inversión" title="Precios" titleAccent="transparentes" description="Planes flexibles para cada etapa de tu negocio. Sin contratos de largo plazo — cancela cuando quieras." />
      <div class="grid md:grid-cols-3 gap-8 items-center">
        {mrtooliaa.pricing.plans.map(plan => (
          <div class:list={['rounded-2xl p-8 card-hover',
            plan.variant === 'popular' ? 'pricing-popular bg-white shadow-xl' :
            plan.variant === 'dark' ? 'bg-navy-500 text-white shadow-sm' :
            'bg-white shadow-sm border border-gray-100'
          ]}>
            <div class:list={['font-bold text-sm uppercase tracking-wider mb-3',
              plan.variant === 'dark' || plan.variant === 'popular' ? 'text-brand-500' : 'text-navy-500'
            ]}>{plan.name}</div>
            <div class="flex items-end gap-1 mb-2">
              {plan.price ? (
                <span class:list={['text-4xl font-black', plan.variant === 'dark' ? '' : 'text-navy-500']}>RD${plan.price.toLocaleString()}</span>
              ) : (
                <span class:list={['text-3xl font-black', plan.variant === 'dark' ? '' : 'text-navy-500']}>{plan.priceLabel}</span>
              )}
            </div>
            <div class:list={['text-sm mb-6', plan.variant === 'dark' ? 'text-white/40' : 'text-gray-400']}>{plan.period}</div>
            <ul class:list={['space-y-3 mb-8 text-sm', plan.variant === 'dark' ? 'text-white/70' : 'text-gray-600']}>
              {plan.features.map(f => (
                <li class="flex items-center gap-2.5">
                  <span class:list={['font-bold', plan.variant === 'dark' ? 'text-brand-400' : 'text-brand-500']}>✓</span> {f}
                </li>
              ))}
            </ul>
            <a href={plan.cta.href} target="_blank" rel="noopener noreferrer"
               class:list={['block text-center font-bold py-3 rounded-xl transition-colors',
                plan.variant === 'popular' ? 'gradient-cta text-white shadow-lg hover:opacity-90' :
                plan.variant === 'dark' ? 'bg-white/15 hover:bg-white/25 text-white border border-white/20' :
                'border-2 border-navy-500 text-navy-500 hover:bg-navy-500 hover:text-white'
              ]}>{plan.cta.text}</a>
          </div>
        ))}
      </div>
      <p class="text-center text-gray-400 text-sm mt-8">* {mrtooliaa.pricing.setup.note}</p>
      <div class="mt-12 text-center">
        <a href={waLink()} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-3 gradient-cta text-white font-bold px-10 py-5 rounded-full text-lg shadow-xl shadow-orange-200 hover:shadow-orange-300 transition-shadow">
          <span class="text-2xl">📅</span>
          Agendar demo gratuita — sin compromiso
        </a>
        <p class="text-gray-400 text-sm mt-3">Respuesta en menos de 2 horas · {site.company.hours}</p>
      </div>
    </div>
  </section>

  <!-- ======================================================
       CTA FINAL
  ======================================================= -->
  <section class="py-20 gradient-hero text-center relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-brand-500/15 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 relative z-10">
      <h2 class="text-4xl sm:text-5xl font-black text-white mb-5">
        {mrtooliaa.ctaFinal.title.line1}<br/>{mrtooliaa.ctaFinal.title.prefix} <span class="text-brand-500">{mrtooliaa.ctaFinal.title.accent}</span>
      </h2>
      <p class="text-white/65 text-lg mb-10 max-w-xl mx-auto">{mrtooliaa.ctaFinal.subtitle}</p>
      <a href={waLink()} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-3 bg-white text-navy-500 font-black px-10 py-5 rounded-full text-xl shadow-2xl hover:shadow-white/20 transition-shadow">
        <span class="text-2xl">💬</span>
        {mrtooliaa.ctaFinal.cta.text.replace('💬 ', '')}
      </a>
      <p class="text-white/40 text-sm mt-5">{mrtooliaa.ctaFinal.note}</p>
    </div>
  </section>
</BaseLayout>
