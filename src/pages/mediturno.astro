---
import BaseLayout from '@layouts/BaseLayout.astro';
import { waLink } from '@data/site';
import { mediturno } from '@data/mediturno';
import SectionHeader from '@components/shared/SectionHeader.astro';
---
<BaseLayout
  seo={{ ...mediturno.seo, jsonLd: mediturno.jsonLd, favicon: mediturno.logos.icon }}
  navVariant="mediturno"
  footerVariant="mediturno"
  waMessage={mediturno.wa.trial}
>

  <!-- HERO -->
  <section class="gradient-medical min-h-screen flex items-center pt-20 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-blue-300/10 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/15 text-white text-sm font-bold px-4 py-2 rounded-full mb-6 badge-pulse">
            <span>💬</span> {mediturno.hero.badge}
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            {mediturno.hero.title.line1}<br/>
            <span class="text-blue-200">{mediturno.hero.title.accent}</span>
          </h1>
          <p class="text-white/70 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl">{mediturno.hero.subtitle}</p>
          <div class="flex flex-wrap gap-4 mb-6">
            <a href={waLink(mediturno.wa.trial)} target="_blank" rel="noopener noreferrer"
               class="bg-white text-medical-500 font-black px-8 py-4 rounded-full text-lg shadow-xl hover:shadow-2xl transition-shadow">
              {mediturno.hero.ctaPrimary.text}
            </a>
            <a href={mediturno.hero.ctaSecondary.href}
               class="border border-white/30 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/10 transition-colors">
              {mediturno.hero.ctaSecondary.text}
            </a>
          </div>
          <p class="text-white/50 text-sm">{mediturno.hero.trialNote}</p>
        </div>
        <div class="hidden lg:block relative">
          <div class="relative bg-white/10 backdrop-blur-sm rounded-2xl border border-white/20 p-6 shadow-2xl">
            <div class="flex items-center gap-3 mb-4 pb-4 border-b border-white/10">
              <img src={mediturno.logos.icon} alt="" width="40" height="40" class="h-10 w-auto rounded-lg" />
              <div><div class="text-white font-bold text-sm">MediTurno IA</div><div class="text-green-400 text-xs">● En línea 24/7</div></div>
            </div>
            <div class="space-y-3">
              <div class="flex justify-end"><div class="bg-white/20 text-white text-sm px-4 py-3 rounded-2xl rounded-br-md max-w-xs">Hola, necesito una cita con la Dra. López para mañana en la tarde</div></div>
              <div class="flex"><div class="bg-white/10 text-white text-sm px-4 py-3 rounded-2xl rounded-bl-md max-w-sm">¡Hola! 👋 La Dra. López tiene disponibilidad mañana a las <strong>2:30 PM</strong> y <strong>4:00 PM</strong>. ¿Cuál prefieres?</div></div>
              <div class="flex justify-end"><div class="bg-white/20 text-white text-sm px-4 py-3 rounded-2xl rounded-br-md">Las 4:00 PM</div></div>
              <div class="flex"><div class="bg-white/10 text-white text-sm px-4 py-3 rounded-2xl rounded-bl-md max-w-sm">✅ <strong>Cita confirmada</strong> con la Dra. López para mañana a las 4:00 PM. Te enviaré un recordatorio 24h antes. ¡Nos vemos!</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-4 bg-medical-500 text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      {mediturno.stats.map(s => (
        <div class="py-3">
          <div class="text-2xl font-black">{s.value}</div>
          <div class="text-white/70 text-sm">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="El problema" title="Tu recepcionista no da abasto" description="Estas 3 situaciones le cuestan dinero a tu clínica cada semana:" />
      <div class="grid md:grid-cols-3 gap-8">
        {mediturno.problems.map(p => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 card-hover text-center">
            <div class="text-4xl mb-4">{p.icon}</div>
            <h3 class="text-xl font-black text-navy-500 mb-3">{p.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="como-funciona" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="Funcionalidades" title="Todo lo que MediTurno IA" titleAccent="hace por ti" />
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mediturno.features.map(f => (
          <div class:list={['rounded-2xl p-6 card-hover border border-gray-100 bg-gradient-to-br', f.gradient]}>
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="font-black text-lg text-navy-500 mb-2">{f.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section id="beneficios" class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="Resultados" title="Beneficios" titleAccent="reales" />
      <div class="grid md:grid-cols-2 gap-6">
        {mediturno.benefits.map(b => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 card-hover flex gap-4">
            <div class="text-3xl flex-shrink-0">{b.icon}</div>
            <div>
              <h3 class="font-black text-lg text-navy-500 mb-1">{b.title}</h3>
              <p class="text-gray-500 text-sm">{b.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TARGET AUDIENCE -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="¿Para quién?" title="Ideal para" titleAccent="tu tipo de clínica" />
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {mediturno.targetAudience.map(t => (
          <div class="text-center p-6 rounded-2xl bg-gray-50 border border-gray-100 card-hover">
            <div class="text-4xl mb-3">{t.icon}</div>
            <h3 class="font-bold text-navy-500 text-sm mb-1">{t.title}</h3>
            <p class="text-gray-400 text-xs">{t.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="precios" class="py-20 gradient-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <SectionHeader eyebrow="Planes" title="Empieza con" titleAccent="14 días gratis" description={mediturno.pricing.trialNote} />
      <div class="grid md:grid-cols-3 gap-8 items-start">
        {mediturno.pricing.plans.map(plan => (
          <div class:list={['rounded-2xl p-8 card-hover',
            plan.variant === 'popular' ? 'pricing-popular bg-white shadow-xl' :
            plan.variant === 'dark' ? 'bg-navy-500 text-white shadow-sm' :
            'bg-white shadow-sm border border-gray-100'
          ]}>
            <h3 class:list={['text-xl font-black mb-1', plan.variant === 'dark' ? 'text-white' : 'text-navy-500']}>{plan.name}</h3>
            <p class:list={['text-sm mb-4', plan.variant === 'dark' ? 'text-white/50' : 'text-gray-500']}>{plan.description}</p>
            {plan.price ? (
              <div class="mb-6">
                <span class:list={['text-4xl font-black', plan.variant === 'dark' ? '' : 'text-navy-500']}>RD${plan.price.toLocaleString()}</span>
                <span class:list={['text-sm ml-1', plan.variant === 'dark' ? 'text-white/40' : 'text-gray-400']}>{plan.period}</span>
                <div class:list={['text-xs mt-1', plan.variant === 'dark' ? 'text-white/30' : 'text-gray-400']}>{plan.priceUSD}</div>
              </div>
            ) : (
              <div class="mb-6">
                <span class="text-3xl font-black">{plan.priceLabel}</span>
                <div class:list={['text-xs mt-1', plan.variant === 'dark' ? 'text-white/30' : 'text-gray-400']}>{plan.priceUSD}</div>
              </div>
            )}
            <ul class:list={['space-y-2.5 mb-8 text-sm', plan.variant === 'dark' ? 'text-white/70' : 'text-gray-600']}>
              {plan.features.map(f => (
                <li class="flex items-center gap-2"><span class="text-medical-500 font-bold">✓</span> {f}</li>
              ))}
            </ul>
            <a href={waLink(mediturno.wa[plan.variant === 'dark' ? 'demo' : plan.variant === 'popular' ? 'pro' : 'basic'])}
               target="_blank" rel="noopener noreferrer"
               class:list={['block text-center font-bold py-3 rounded-xl transition-colors',
                plan.variant === 'popular' ? 'bg-medical-500 hover:bg-medical-600 text-white shadow-lg' :
                plan.variant === 'dark' ? 'bg-white/15 hover:bg-white/25 text-white border border-white/20' :
                'border-2 border-medical-500 text-medical-500 hover:bg-medical-500 hover:text-white'
              ]}>{plan.cta?.text ?? 'Empezar gratis'}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-20 gradient-medical text-center relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 relative z-10">
      <h2 class="text-4xl sm:text-5xl font-black text-white mb-5">
        Empieza hoy.<br/><span class="text-blue-200">14 días gratis,</span><br/>sin complicaciones.
      </h2>
      <p class="text-white/70 text-lg mb-10 max-w-xl mx-auto">
        Configura MediTurno IA en menos de 1 hora. Tu primer paciente puede agendar esta misma noche.
      </p>
      <a href={waLink(mediturno.wa.start)} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-3 bg-white text-medical-500 font-black px-10 py-5 rounded-full text-xl shadow-2xl hover:shadow-white/20 transition-shadow">
        <span class="text-2xl">💬</span> Prueba MediTurno IA gratis
      </a>
      <p class="text-white/40 text-sm mt-5">Sin contrato · Sin tarjeta de crédito · Cancela cuando quieras</p>
    </div>
  </section>
</BaseLayout>
